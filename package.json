{
  "name": "tc-bot",
  "version": "7.7.6",
  "description": "Ark of War Theorycrafter Bot",
  "keywords": [],
  "homepage": "https://github.com/ishark5060/tc-bot#readme",
  "bugs": {
    "url": "https://github.com/ishark5060/tc-bot/issues"
  },
  "license": "MIT",
  "author": "Shark5060",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishark5060/tc-bot.git"
  },
  "type": "module",
  "main": "dist/tc-bot.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/tc-bot.js",
    "deploy": "tsx src/deployCommands.ts",
    "lint": "oxlint --node-plugin --promise-plugin --import-plugin --vitest-plugin .",
    "format": "oxfmt --write .",
    "check-format": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "node run-quality-checks.mjs",
    "typecheck": "tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.64.0",
    "@googleapis/sheets": "^13.0.1",
    "@pm2/io": "^6.1.0",
    "better-sqlite3": "^12.9.0",
    "discord.js": "^14.26.3",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=25.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.0.0"
}
